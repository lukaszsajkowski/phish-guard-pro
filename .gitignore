# PhishGuard Pro - Monorepo .gitignore

# =============================================================================
# Dependencies
# =============================================================================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
env/

# =============================================================================
# Next.js / React
# =============================================================================
.next/
out/
.vercel

# =============================================================================
# Testing
# =============================================================================
coverage/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.pytest_cache/
.hypothesis/

# =============================================================================
# Build
# =============================================================================
*.manifest
*.spec
.cache

# =============================================================================
# Environment Variables
# =============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# =============================================================================
# IDE / Editor
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
*.pem

# =============================================================================
# Logs
# =============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pip-log.txt

# =============================================================================
# TypeScript
# =============================================================================
*.tsbuildinfo

# =============================================================================
# Linting / Formatting
# =============================================================================
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# =============================================================================
# Supabase
# =============================================================================
supabase/.branches
supabase/.temp
