# PhishGuard Pro - Environment Configuration
# Copy this file to .env and configure for your environment
# This file is shared between frontend (Next.js) and backend (FastAPI)

# =============================================================================
# SUPABASE (Shared)
# =============================================================================
# Get these from: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend-only (service role key for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Backend-only (direct PostgreSQL connection for LangGraph checkpointing)
# Get from: Supabase Dashboard -> Settings -> Database -> Connection string -> URI
SUPABASE_DB_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# =============================================================================
# API (Shared)
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# OPENAI (Backend only)
# =============================================================================
OPENAI_API_KEY=your_openai_api_key
OPENAI_PRIMARY_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# =============================================================================
# APPLICATION (Backend)
# =============================================================================
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# IOC ENRICHMENT (Backend only)
# =============================================================================
BITCOINABUSE_API_KEY=your-bitcoinabuse-api-key
VIRUSTOTAL_API_KEY=your-virustotal-api-key
